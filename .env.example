# ============================================
# Virtual Black Eagles - 환경 변수 설정
# ============================================
# 이 파일을 .env로 복사한 후 실제 값을 입력하세요:
#   copy .env.example .env
#
# Render 배포 시에는 Render Dashboard > Environment에서 설정하세요.

# ─── Flask ───
SECRET_KEY=change-this-to-a-random-secret-key

# ─── Google OAuth (Google Cloud Console에서 발급) ───
# 1. https://console.cloud.google.com/ 접속
# 2. 새 프로젝트 생성 또는 기존 프로젝트 선택
# 3. APIs & Services > OAuth consent screen 설정
# 4. APIs & Services > Credentials > Create Credentials > OAuth 2.0 Client ID
# 5. Application type: Web application
# 6. Authorized redirect URIs 추가:
#    - 로컬: http://localhost:5000/auth/google/callback
#    - 배포: https://your-domain.com/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# ─── SendGrid 이메일 (https://sendgrid.com/) ───
# 1. https://signup.sendgrid.com/ 에서 무료 계정 생성
# 2. Settings > API Keys > Create API Key (Full Access)
# 3. 발신자 인증: Settings > Sender Authentication > Single Sender Verification
#    (발신 이메일 주소 인증 필요)
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here
SENDGRID_FROM_EMAIL=your-verified-email@example.com

# ─── Flask-Mail (SMTP 폴백 - SendGrid 사용 시 설정 불필요) ───
# MAIL_SERVER=smtp.naver.com
# MAIL_PORT=465
# MAIL_USE_SSL=true
# MAIL_USE_TLS=false
# MAIL_USERNAME=rr3340@naver.com
# MAIL_PASSWORD=your-naver-app-password
# MAIL_DEFAULT_SENDER=rr3340@naver.com

# ─── 관리자 계정 (하드코딩 백업용) ───
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=blackeagles2025
